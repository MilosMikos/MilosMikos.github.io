        </li>
        <li lang-selection="TR">
          <img src="https://cdn.countryflags.com/thumbs/turkey/flag-800.png" />
          Türkçe
        </li>
        <li lang-selection="SW">
          <img src="https://cdn.countryflags.com/thumbs/sweden/flag-800.png" />
          Svenska
        </li>
        <li lang-selection="FI">
          <img src="https://cdn.countryflags.com/thumbs/finland/flag-800.png" />
